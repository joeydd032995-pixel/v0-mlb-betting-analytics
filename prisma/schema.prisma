generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  @@unique([userId, gameId])
  @@index([userId])
  @@map("watchlist")
}

model Bet {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  amount    Float
  odds      Float
  prediction String   // "NRFI" or "YRFI"
  result    String?  // "NRFI" or "YRFI" or null if pending
  pnl       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([gameId])
  @@map("bets")
}

model Bankroll {
  id              String   @id @default(cuid())
  userId          String   @unique
  startingBalance Float
  currentBalance  Float
  updatedAt       DateTime @updatedAt

  @@map("bankroll")
}

model GameResult {
  gamePk   Int      @id
  date     String
  season   Int
  homeTeam String
  awayTeam String
  homeRuns Int
  awayRuns Int
  nrfi     Boolean
  syncedAt DateTime @default(now())

  @@index([date])
  @@index([season])
  @@map("game_results")
}

model ModelPrediction {
  id              String   @id
  date            String
  season          Int
  homeTeam        String
  awayTeam        String
  homePitcher     String   @default("")
  awayPitcher     String   @default("")
  nrfiProbability Float
  prediction      String
  confidence      String
  confidenceScore Float
  poissonNrfi     Float
  zipNrfi         Float
  markovNrfi      Float
  ensembleNrfi    Float
  modelConsensus  Float    @default(0.5)
  actualResult    String?
  correct         Boolean?
  status          String   @default("pending")
  backtested      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([season])
  @@index([status])
  @@map("model_predictions")
}

// Written only when ENABLE_DIAGNOSTICS=true — tracks per-game ensemble diagnostics.
model EnsembleDiagnostic {
  id              String   @id @default(cuid())
  gameId          String
  date            String
  poissonWeight   Float
  zipWeight       Float
  markovWeight    Float
  mapreWeight     Float
  logisticWeight  Float
  nnWeight        Float
  hierBayesWeight Float
  rawEnsemble7    Float
  calibrated      Float
  finalBlended    Float
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([gameId])
  @@map("ensemble_diagnostics")
}
