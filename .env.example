# =============================================================================
# NRFI/YRFI Prediction Engine — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local


# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION  (Required for sign-in / sign-up)
# -----------------------------------------------------------------------------
# Create a free Clerk application at https://clerk.com
# 1. Go to https://dashboard.clerk.com → "Create application"
# 2. Choose any name, enable Email/Password + Google/Apple (optional)
# 3. Copy your keys from the "API Keys" tab into .env.local
#
# publishable key (safe to expose — prefixed NEXT_PUBLIC_)
# Format: pk_test_<base64string>  (for development)
#         pk_live_<base64string>  (for production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<paste_your_clerk_publishable_key_here>

# secret key (NEVER commit to git — server-side only, keep in .env.local)
# Format: sk_test_<base64string>  (for development)
#         sk_live_<base64string>  (for production)
CLERK_SECRET_KEY=<paste_your_clerk_secret_key_here>

# Where Clerk's hosted components redirect for sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where to land after a successful sign-in or sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Where to land after signing out
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# (Optional) Webhook secret — needed only if you add Clerk webhooks later
# CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx



# -----------------------------------------------------------------------------
# STRIPE PAYMENTS  (Required for paid tiers — Daily / Weekly / Monthly / Annual)
# -----------------------------------------------------------------------------
# Sign up at https://stripe.com and create a new project.
# 1. Go to Developers → API Keys → copy your secret key below.
# 2. Create 4 Products in Stripe Dashboard → Products → Add Product.
#    One product per cadence: Daily ($3.99), Weekly ($8.99), Monthly ($23.99), Annual ($127.99).
#    For each, set: recurring billing, the exact price, appropriate interval.
# 3. Copy each price's ID (starts with "price_") into the price vars below.
# 4. Set up the webhook endpoint in Stripe → Developers → Webhooks:
#    Endpoint URL: https://your-domain.com/api/webhooks/stripe
#    Events to subscribe to:
#      checkout.session.completed
#      customer.subscription.created
#      customer.subscription.updated
#      customer.subscription.deleted
#      invoice.payment_failed
#    Copy the webhook Signing Secret into STRIPE_WEBHOOK_SECRET below.
#
# Secret key — server-only, NEVER expose to the browser.
STRIPE_SECRET_KEY=<paste_your_stripe_secret_key_here>

# Webhook signing secret (from Stripe Dashboard → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=<paste_your_stripe_webhook_signing_secret_here>

# Stripe Price IDs — one per billing cadence (copy from Stripe → Products → price_xxx)
STRIPE_PRICE_DAILY=<price_xxxxxxxxxxxxxxxxxxxxxxxx>
STRIPE_PRICE_WEEKLY=<price_xxxxxxxxxxxxxxxxxxxxxxxx>
STRIPE_PRICE_MONTHLY=<price_xxxxxxxxxxxxxxxxxxxxxxxx>
STRIPE_PRICE_ANNUAL=<price_xxxxxxxxxxxxxxxxxxxxxxxx>



# -----------------------------------------------------------------------------
# VERCEL POSTGRES  (Required for subscription tracking + free-tier daily quota)
# -----------------------------------------------------------------------------
# 1. In your Vercel project: Storage → Create Database → Postgres → create.
# 2. Vercel auto-populates POSTGRES_* vars in the Vercel environment.
# 3. For local dev: copy these from Vercel → Settings → Environment Variables.
# 4. Run the DB migration once: npx drizzle-kit push
#    (requires POSTGRES_URL to be set in your local .env.local)
#
POSTGRES_URL=<postgres://user:password@host:5432/dbname>
POSTGRES_PRISMA_URL=<postgres://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15>
POSTGRES_URL_NON_POOLING=<postgres://user:password@host:5432/dbname>
POSTGRES_USER=<db_user>
POSTGRES_HOST=<db_host>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DATABASE=<db_name>



# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Required APIs:
#   • The Odds API (for NRFI/YRFI live odds)
#   • OpenWeatherMap (for stadium weather conditions)
#   • MLB Stats API (built-in, no auth needed)
#
# Optional APIs:
#   • SportsBlaze (enhanced player/team analytics)
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# =============================================================================


# -----------------------------------------------------------------------------
# THE ODDS API  (Required for live NRFI/YRFI odds and value bet identification)
# -----------------------------------------------------------------------------
# Sign up at https://the-odds-api.com
# Free tier: 500 requests/month
# Market key for NRFI/YRFI: batter_first_inning_scored
# Docs: https://the-odds-api.com/liveapi/guides/v4/
#
THE_ODDS_API_KEY=your_the_odds_api_key_here

# Comma-separated list of bookmakers to pull odds from.
# Options: draftkings, fanduel, betmgm, caesars, pointsbet, barstool, wynnbet
# Leave blank to use all available bookmakers.
THE_ODDS_API_BOOKMAKERS=draftkings,fanduel,betmgm,caesars


# -----------------------------------------------------------------------------
# OPENWEATHERMAP API  (Required for live weather at stadium game time)
# -----------------------------------------------------------------------------
# Sign up at https://openweathermap.org/api
# Use the "Current Weather Data" endpoint (free tier: 1,000 calls/day)
# Optionally use the "One Call API 3.0" for hourly forecasts at game time.
# Docs: https://openweathermap.org/api
#
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Units for temperature: imperial (°F) or metric (°C)
# The engine always stores temperature in Fahrenheit; set to imperial.
OPENWEATHER_UNITS=imperial


# -----------------------------------------------------------------------------
# MLB STATS API  (Built-in — no authentication required)
# -----------------------------------------------------------------------------
# Uses MLB.com's official free API: https://statsapi.mlb.com
# ✓ Completely free
# ✓ No API key required
# ✓ No request limits (reasonable rate-limiting expected)
# ✓ Access to all current and historical seasons
# ✓ Direct source of truth for MLB game data
#
# No environment variables needed — this API is used automatically for:
# - Game schedules and live game data
# - Pitcher statistics and ERA
# - Team statistics and OPS
#
# Docs: https://github.com/toddrob99/MLB-StatsAPI


# -----------------------------------------------------------------------------
# SPORTSBLAZE API  (Optional — enhanced MLB player and team analytics)
# -----------------------------------------------------------------------------
# Sign up at https://sportsblaze.com
# Authenticate via query param: ?key=your_key
# Docs: https://docs.sportsblaze.com
# Used for: advanced batting splits, pitcher xStats, matchup analytics
#
SPORTSBLAZE_API_KEY=your_sportsblaze_api_key_here

# SportsBlaze base URL
SPORTSBLAZE_BASE_URL=https://api.sportsblaze.com


# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Full URL of your deployed app (used for OpenGraph metadata and canonical URLs)
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MLB season year (used to scope all stat API requests)
NEXT_PUBLIC_MLB_SEASON=2026

# Minimum edge (as decimal) required to flag a value bet.
# Default: 0.03 (3%). Raise to reduce false positives.
NEXT_PUBLIC_MIN_KELLY_EDGE=0.03

# Fractional Kelly multiplier for bet sizing (0.25 = 25% Kelly).
# Lower values = more conservative sizing.
NEXT_PUBLIC_KELLY_FRACTION=0.25

# Cache TTL in seconds for MLB schedule/pitcher data
# 300 = re-fetch every 5 minutes during live game day
DATA_REVALIDATE_SECONDS=300

# Cache TTL for odds data (odds move faster — refresh more often)
ODDS_REVALIDATE_SECONDS=60


# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING (Optional)
# -----------------------------------------------------------------------------

# Vercel Analytics is already included via @vercel/analytics/next.
# No key required when deployed on Vercel.
# VERCEL_ANALYTICS_ID=

# Sentry DSN for error monitoring (optional)
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production



# =============================================================================
# NOTES ON API USAGE
# =============================================================================
#
# Daily call estimates (15 MLB games/day):
#   The Odds API       ~30 calls/day   (NRFI/YRFI odds per game)
#   OpenWeatherMap     ~20 calls/day   (1 per outdoor stadium)
#   MLB Stats API      ~40 calls/day   (schedule + pitcher stats — unlimited free)
#   SportsBlaze        ~15 calls/day   (optional enhanced splits)
#   ─────────────────────────────────
#   Total              ~105 calls/day  — within all free tiers (MLB Stats unlimited)
#
# The app uses Next.js fetch() caching with revalidation to minimize
# redundant API calls. Odds data is refreshed every 60 seconds;
# schedule and pitcher data every 5 minutes.
#
# Benefits of using MLB Stats API:
# - No cost (completely free)
# - No authentication key required
# - No artificial plan tiers or seasonal restrictions
# - Direct MLB.com data (official source of truth)
# - Instant access to 2026 games and current season stats
#
# See README.md → "API Integrations" for full documentation and
# example code for connecting each service.
# =============================================================================
