# =============================================================================
# NRFI/YRFI Prediction Engine — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# =============================================================================


# -----------------------------------------------------------------------------
# THE ODDS API  (Required for live NRFI/YRFI odds and value bet identification)
# -----------------------------------------------------------------------------
# Sign up at https://the-odds-api.com
# Free tier: 500 requests/month
# Market key: batter_first_inning_scored  (NRFI/YRFI props)
#
THE_ODDS_API_KEY=your_the_odds_api_key_here

# Comma-separated list of bookmakers to pull odds from.
# Options: draftkings, fanduel, betmgm, caesars, pointsbet, barstool, wynnbet
# Leave blank to use all available bookmakers.
THE_ODDS_API_BOOKMAKERS=draftkings,fanduel,betmgm,caesars


# -----------------------------------------------------------------------------
# OPENWEATHERMAP API  (Required for live weather at stadium game time)
# -----------------------------------------------------------------------------
# Sign up at https://openweathermap.org/api
# Use the "Current Weather Data" endpoint (free tier: 1,000 calls/day)
# Optionally use the "One Call API 3.0" for hourly forecasts at game time.
#
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Units for temperature: imperial (°F) or metric (°C)
# The engine always stores temperature in Fahrenheit; set to imperial.
OPENWEATHER_UNITS=imperial


# -----------------------------------------------------------------------------
# SPORTS DATA IO — MLB API  (Optional — enhanced first-inning stat splits)
# -----------------------------------------------------------------------------
# Sign up at https://sportsdata.io/mlb-api
# Free trial: 1,000 API calls. Paid plans from $9/month.
# Used for: per-inning ERA, BABIP splits, and first-batter OBP data.
# If omitted, the engine falls back to MLB Stats API splits.
#
SPORTSDATA_API_KEY=your_sportsdata_io_key_here


# -----------------------------------------------------------------------------
# MLB STATS API  (No key required — public API)
# -----------------------------------------------------------------------------
# The official MLB Stats API is free and requires no authentication.
# The base URL is set below. Override only if MLB changes their API host.
# Docs: https://statsapi.mlb.com/api/v1/
#
MLB_STATS_API_BASE=https://statsapi.mlb.com/api/v1


# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Full URL of your deployed app (used for OpenGraph metadata and canonical URLs)
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MLB season year (used to scope all stat API requests)
NEXT_PUBLIC_MLB_SEASON=2025

# Minimum edge (as decimal) required to flag a value bet.
# Default: 0.03 (3%). Raise to reduce false positives.
NEXT_PUBLIC_MIN_KELLY_EDGE=0.03

# Fractional Kelly multiplier for bet sizing (0.25 = 25% Kelly).
# Lower values = more conservative sizing.
NEXT_PUBLIC_KELLY_FRACTION=0.25

# Cache TTL in seconds for MLB schedule/pitcher data
# 300 = re-fetch every 5 minutes during live game day
DATA_REVALIDATE_SECONDS=300

# Cache TTL for odds data (odds move faster — refresh more often)
ODDS_REVALIDATE_SECONDS=60


# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING (Optional)
# -----------------------------------------------------------------------------

# Vercel Analytics is already included via @vercel/analytics/next.
# No key required when deployed on Vercel.
# For self-hosted deployments, set VERCEL_ANALYTICS_ID if needed.
# VERCEL_ANALYTICS_ID=

# Sentry DSN for error monitoring (optional)
# Sign up at https://sentry.io — free tier available
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production


# =============================================================================
# NOTES ON API USAGE
# =============================================================================
#
# Daily call estimates (15 MLB games/day):
#   MLB Stats API     ~50 calls/day   (schedule + pitcher stats)
#   The Odds API      ~30 calls/day   (NRFI/YRFI odds per game)
#   OpenWeatherMap    ~20 calls/day   (1 per outdoor stadium)
#   Sports Data IO    ~15 calls/day   (optional enhanced splits)
#   ─────────────────────────────────
#   Total             ~115 calls/day  — within all free tiers
#
# The app uses Next.js fetch() caching with revalidation to minimize
# redundant API calls. Odds data is refreshed every 60 seconds;
# schedule and pitcher data every 5 minutes.
#
# See README.md → "API Integrations" for full documentation and
# example code for connecting each service.
# =============================================================================
